#!/bin/bash
# Book Reader - Simple, Stable Terminal UI
# Routes between interactive file browser and batch modes

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VENV_PYTHON="$SCRIPT_DIR/venv/bin/python3"

# Use venv Python if available, otherwise fall back to system Python
if [ -x "$VENV_PYTHON" ]; then
    PYTHON_CMD="$VENV_PYTHON"
else
    PYTHON_CMD="python3"
fi

# Check for --batch flag
if [[ "$*" == *"--batch"* ]]; then
    # Batch mode - use non-interactive CLI
    exec "$PYTHON_CMD" "$SCRIPT_DIR/book_reader.py" "$@"
else
    # Interactive mode - use stable file browser
    exec "$PYTHON_CMD" "$SCRIPT_DIR/book_reader_simple.py"
fi
